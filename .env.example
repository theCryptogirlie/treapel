# Copy this file to .env and fill in your testnet credentials

# ── Freelancer (Receiver) ──
FREELANCER_WALLET_ADDRESS=https://ilp.interledger-test.dev/your-freelancer-handle
FREELANCER_KEY_ID=your-freelancer-key-id
FREELANCER_PRIVATE_KEY_PATH=./freelancer.key

# ── Client (Sender) ──
CLIENT_WALLET_ADDRESS=https://ilp.interledger-test.dev/your-client-handle
CLIENT_KEY_ID=your-client-key-id
CLIENT_PRIVATE_KEY_PATH=./client.key

# ── Invoice Config ──
INVOICE_AMOUNT=10000
ASSET_CODE=USD
ASSET_SCALE=3

# ── Redirect ──
REDIRECT_URL=http://localhost:3000/payment/confirm
